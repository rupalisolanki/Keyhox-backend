// Prisma schema file for Keyhox database models. Defines datasource and generator. Models will be added in Step 2.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum KeyStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TicketType {
  SUPPORT
  SELLER_APPLICATION
  CONTACT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  keys      Key[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  price       Decimal  @db.Decimal(10, 2)
  category    String
  imageUrl    String?
  metadata    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  keys        Key[]
  orders      Order[]
}

model Key {
  id         String     @id @default(uuid())
  licenseKey String     @unique
  status     KeyStatus  @default(AVAILABLE)
  productId  String
  assignedTo String?
  assignedAt DateTime?
  createdAt  DateTime   @default(now())
  product    Product    @relation(fields: [productId], references: [id])
  user       User?      @relation(fields: [assignedTo], references: [id])
  order      Order?     @relation("OrderKey")
  @@map("keys")
}

model Order {
  id                   String      @id @default(uuid())
  userId               String
  productId            String
  keyId                String?     @unique
  amount               Decimal     @db.Decimal(10, 2)
  status               OrderStatus @default(PENDING)
  stripePaymentIntentId String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  user                 User        @relation(fields: [userId], references: [id])
  product              Product     @relation(fields: [productId], references: [id])
  key                  Key?        @relation("OrderKey", fields: [keyId], references: [id])
}

model SupportTicket {
  id        String       @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  type      TicketType   @default(SUPPORT)
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
}